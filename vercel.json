{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build:vercel",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/server/**"
    }
  },
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
